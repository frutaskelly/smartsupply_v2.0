# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  SmartSupply v2.0 — environment template                                   ║
# ║  Copy to .env and fill in real values. .env is gitignored.                 ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Database (local dev = docker postgres; prod = Supabase) ─────────────────
# Local dev points at the docker postgres service.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/smartsupply_v2
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:postgres@postgres:5432/smartsupply_v2

# Supabase Postgres (direct connection) — used to apply migrations to the
# shared/cloud project. Leave blank for pure-local dev.
SUPABASE_DB_URL=postgresql+psycopg2://postgres:[DB_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Role the backend connects as for request-scoped queries. MUST be a
# non-superuser role (no BYPASSRLS) so RLS is actually enforced.
DB_APP_ROLE=app_user

# ─── Supabase Auth ────────────────────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_PROJECT_REF=[PROJECT_REF]
# Publishable (anon) key — safe for the browser bundle.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Secret (service-role) key — backend ONLY. Needed to create users / reset
# passwords from the operator console. NEVER expose to the frontend.
SUPABASE_SECRET_KEY=sb_secret_xxx
# JWTs are verified against the project JWKS (ES256). No shared secret needed.
SUPABASE_JWKS_URL=https://[PROJECT_REF].supabase.co/auth/v1/.well-known/jwks.json

# ─── Anthropic (Productos: SAT classifier + vision) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── Facturama (CFDI 4.0) ─────────────────────────────────────────────────────
# Ambiente por URL: sandbox (pruebas) o https://api.facturama.mx (timbres REALES).
FACTURAMA_BASE_URL=https://apisandbox.facturama.mx
FACTURAMA_API_KEY=
FACTURAMA_USER=
FACTURAMA_PASSWORD=
# Cancelación simulada: el sandbox NO cancela (500). true = no llama al PAC, solo
# aplica la lógica interna (estado + inventario por motivo). En PRODUCCIÓN: false.
FACTURAMA_FAKE_CANCEL=true
# Permite usar el host de producción (api.facturama.mx). Mantener false hasta tener
# CSD/credenciales de producción; en PRODUCCIÓN: true (+ BASE_URL=https://api.facturama.mx).
FACTURAMA_ALLOW_PRODUCTION=false
# Envía Serie/Folio propios al PAC. Solo si esas series están dadas de alta en la
# cuenta/sucursal de Facturama; de lo contrario el PAC rechaza con 400.
FACTURAMA_SEND_SERIE=false
# Emisor: vacío = CSD por defecto de la cuenta. En PRODUCCIÓN fija el RFC real cuyo
# CSD está cargado en Facturama (y, opcionalmente, nombre/régimen/lugar de expedición).
FACTURAMA_ISSUER_RFC=
FACTURAMA_ISSUER_NAME=
FACTURAMA_ISSUER_REGIMEN=
FACTURAMA_EXPEDITION_PLACE=

# ── Producción (referencia): para timbrar REAL, en el .env de prod usa ──────────
#   FACTURAMA_BASE_URL=https://api.facturama.mx
#   FACTURAMA_ALLOW_PRODUCTION=true
#   FACTURAMA_FAKE_CANCEL=false
#   FACTURAMA_USER / FACTURAMA_PASSWORD = credenciales de la cuenta de PRODUCCIÓN
#   FACTURAMA_ISSUER_RFC = RFC real del emisor (CSD cargado en Facturama)
# Ver PLAN-facturama-produccion.md para el checklist completo.

# ─── CORS (comma-separated) ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3012,http://localhost:3000

# ─── Platform operator allowlist (comma-separated emails) ────────────────────
PLATFORM_OPERATORS=

# ─── Frontend (NEXT_PUBLIC_* are baked into the bundle at BUILD time) ────────
NEXT_PUBLIC_API_URL=http://localhost:8011
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
